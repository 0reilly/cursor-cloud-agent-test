# Fastlane Environment Variables for App Store Connect API
# Copy this file to .env.fastlane.local and fill in your values
# Then run: source .env.fastlane.local

# App Store Connect API Key (from ApiKey_8IVCOS4E8LYG.p8)
export APP_STORE_CONNECT_API_KEY_ID="8IVCOS4E8LYG"
export APP_STORE_CONNECT_API_ISSUER_ID="YOUR_ISSUER_ID_HERE"
export APP_STORE_CONNECT_API_KEY_PATH="./AuthKey_8IVCOS4E8LYG.p8"

# Apple Developer Team (optional, for Fastlane Appfile)
export APPLE_DEVELOPER_TEAM_ID="YOUR_TEAM_ID_HERE"
export APPLE_DEVELOPER_APPLE_ID="your-apple-id@example.com"

# For reference (not used directly):
# - Key ID: 8IVCOS4E8LYG (from filename)
# - Issuer ID: Get from App Store Connect → Users and Access → Keys
# - Team ID: Get from Apple Developer Account → Membership