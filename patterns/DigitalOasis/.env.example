# DigitalOasis Environment Variables
# Copy this file to .env and fill in your values

# App Configuration
EXPO_PUBLIC_APP_NAME="Patterns"
EXPO_PUBLIC_APP_VERSION=1.0.0

# In-App Purchases
# Note: IAP product IDs are configured in App Store Connect / Google Play Console
EXPO_PUBLIC_IAP_SUBSCRIPTION_ID=patterns_pro_yearly

# Apple Developer API (Optional - for automated app management)
# APPLE_DEVELOPER_API_KEY_ID=
# APPLE_DEVELOPER_API_ISSUER_ID=
# APPLE_DEVELOPER_API_PRIVATE_KEY_PATH=

# Backend API (Future integration)
# EXPO_PUBLIC_API_URL=https://api.digitaloasis.app/v1
# EXPO_PUBLIC_ANALYTICS_KEY=

# Feature Flags
EXPO_PUBLIC_ENABLE_IAP_SANDBOX=true
EXPO_PUBLIC_ENABLE_ADVANCED_ANALYTICS=false

# Development
EXPO_PUBLIC_DEBUG=true