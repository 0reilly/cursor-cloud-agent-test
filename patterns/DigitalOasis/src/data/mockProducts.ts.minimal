// @ts-nocheck
import { DigitalProduct } from '../types';
import darkPatterns from './mockDarkPatterns';
import sideEffects from './mockSideEffects';
import studies from './mockStudies';

// Helper to find studies by affected products
const getStudiesForProduct = (productName: string) => {
  return studies.filter(study => 
    study.productsAffected.some(p => 
      p.toLowerCase().includes(productName.toLowerCase()) ||
      productName.toLowerCase().includes(p.toLowerCase())
    )
  );
};

export const products: DigitalProduct[] = [
  {
