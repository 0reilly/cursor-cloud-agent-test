        prevalence: 'common',
        description: 'Uses guilt-inducing language when users decline notifications or features.'
      },
      {
        pattern: darkPatterns.find(dp => dp.id === 'dp6')!,
        prevalence: 'common',
        description: 'Makes account deletion difficult and requires navigating multiple screens.'
      }
    ],
    sideEffects: [
      sideEffects.find(se => se.id === 'se1')!,
