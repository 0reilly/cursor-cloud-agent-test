import React, { useState } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  TouchableOpacity,
  TextInput,
  FlatList,
  Alert,
  Image,
} from 'react-native';
import { SafeAreaView } from 'react-native-safe-area-context';
import { Ionicons } from '@expo/vector-icons';
import { useNavigation } from '@react-navigation/native';
import { NativeStackNavigationProp } from '@react-navigation/native-stack';
// import * as ImagePicker from 'expo-image-picker'; // Temporarily disabled for Node 16 compatibility
import { RootStackParamList } from '../navigation';
import { products, categories } from '../data';

type SearchScreenNavigationProp = NativeStackNavigationProp<RootStackParamList>;

export default function SearchScreen() {
  const navigation = useNavigation<SearchScreenNavigationProp>();
  const [searchQuery, setSearchQuery] = useState('');
  const [activeCategory, setActiveCategory] = useState<string | null>(null);
  const [selectedImage, setSelectedImage] = useState<string | null>(null);
  const [scanning, setScanning] = useState(false);
  const [scanResults, setScanResults] = useState<any>(null);

  const filteredProducts = products.filter(product => {
    const matchesSearch = product.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      product.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
      product.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));
    const matchesCategory = !activeCategory || product.category === activeCategory;
    return matchesSearch && matchesCategory;
  });

  const getRiskColor = (score: number) => {
    if (score >= 70) return '#ef4444';
    if (score >= 50) return '#f59e0b';
    return '#10b981';
  };

  const simulateDarkPatternDetection = (imageUri: string) => {
    // Mock analysis results
    const detectedPatterns = [
      { name: 'Forced Continuity', confidence: 85, severity: 'High' },
      { name: 'Hidden Costs', confidence: 72, severity: 'Medium' },
      { name: 'Roach Motel', confidence: 64, severity: 'Medium' },
    ];
    
    const mockProduct = {
      name: 'Detected App Interface',
      category: 'mobile_app',
      riskScore: 74,
      darkPatterns: detectedPatterns,
      recommendations: [
        'Look for cancel button visibility',
        'Check subscription renewal notices',
        'Verify pricing transparency'
      ],
      detectedAt: new Date().toLocaleString()
    };
    
    return mockProduct;
  };

  const pickImage = async () => {
    try {
      const permissionResult = await ImagePicker.requestMediaLibraryPermissionsAsync();
      if (!permissionResult.granted) {
        Alert.alert('Permission Required', 'Camera roll access is needed to scan images');
        return;
      }

      const result = await ImagePicker.launchImageLibraryAsync({
        mediaTypes: ImagePicker.MediaTypeOptions.Images,
        allowsEditing: true,
        aspect: [4, 3],
        quality: 0.8,
      });

      if (!result.canceled && result.assets[0]) {
        setSelectedImage(result.assets[0].uri);
        setScanning(true);
        setScanResults(null);
        
        // Simulate scanning/analysis delay
        setTimeout(() => {
          const analysisResults = simulateDarkPatternDetection(result.assets[0].uri);
          setScanResults(analysisResults);
          setScanning(false);
          Alert.alert('Scan Complete', `Found ${analysisResults.darkPatterns.length} dark patterns with ${analysisResults.riskScore}% risk score`);
        }, 1500);
      }
    } catch (error) {
      Alert.alert('Error', 'Failed to pick image');
      setScanning(false);
    }
  };

  const clearScan = () => {
    setSelectedImage(null);
    setScanResults(null);
    setScanning(false);
  };

  return (
    <SafeAreaView style={styles.container}>
      <ScrollView showsVerticalScrollIndicator={false}>
        {/* Header */}
        <View style={styles.header}>
          <Text style={styles.headerTitle}>Search Products</Text>
          <Text style={styles.headerSubtitle}>Find digital products and see their dark patterns</Text>
        </View>

        {/* Search Bar */}
        <View style={styles.searchContainer}>
          <Ionicons name="search" size={20} color="#9ca3af" />
          <TextInput
            style={styles.searchInput}
            placeholder="Search by name, category, or dark pattern..."
            value={searchQuery}
            onChangeText={setSearchQuery}
            autoCapitalize="none"
          />
          <TouchableOpacity onPress={pickImage} style={{ marginLeft: 8 }} disabled={scanning}>
            <Ionicons name={scanning ? "scan" : "camera-outline"} size={20} color={scanning ? "#10b981" : "#9ca3af"} />
          </TouchableOpacity>
          {searchQuery.length > 0 && (
            <TouchableOpacity onPress={() => setSearchQuery('')}>
              <Ionicons name="close-circle" size={20} color="#9ca3af" />
            </TouchableOpacity>
          )}
        </View>

        {/* Categories Filter */}
        <View style={styles.section}>
          <Text style={styles.sectionTitle}>Categories</Text>
          <ScrollView horizontal showsHorizontalScrollIndicator={false} style={styles.categoriesScroll}>
            <TouchableOpacity
              style={[styles.categoryFilter, !activeCategory && styles.categoryFilterActive]}
              onPress={() => setActiveCategory(null)}
            >
              <Text style={[styles.categoryFilterText, !activeCategory && styles.categoryFilterTextActive]}>
                All
              </Text>
            </TouchableOpacity>
            {categories.map((category) => (
              <TouchableOpacity
                key={category.id}
                style={[
                  styles.categoryFilter,
                  activeCategory === category.id && styles.categoryFilterActive
                ]}
                onPress={() => setActiveCategory(activeCategory === category.id ? null : category.id)}
              >
                <Text style={[
                  styles.categoryFilterText,
                  activeCategory === category.id && styles.categoryFilterTextActive
                ]}>
                  {category.name}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>
        </View>

        {/* Scan Results */}
        {(selectedImage || scanResults) && (
          <View style={styles.section}>
            <View style={styles.resultsHeader}>
              <Text style={styles.sectionTitle}>Scan Results</Text>
              <TouchableOpacity onPress={clearScan}>
                <Ionicons name="close-circle" size={24} color="#9ca3af" />
              </TouchableOpacity>
            </View>
            
            {scanning ? (
              <View style={styles.scanningContainer}>
                <Ionicons name="scan" size={48} color="#10b981" />
                <Text style={styles.scanningText}>Analyzing image for dark patterns...</Text>
              </View>
            ) : (
              <>
                {selectedImage && (
                  <View style={styles.imagePreviewContainer}>
                    <Image source={{ uri: selectedImage }} style={styles.imagePreview} />
                  </View>
                )}
                
                {scanResults && (
                  <View style={styles.scanResultsContainer}>
                    <View style={styles.scanResultHeader}>
                      <Text style={styles.scanResultTitle}>{scanResults.name}</Text>
                      <View style={[styles.riskBadge, { backgroundColor: getRiskColor(scanResults.riskScore) }]}>
                        <Text style={styles.riskScore}>{scanResults.riskScore}% risk</Text>
                      </View>
                    </View>
                    
                    <Text style={styles.scanResultSubtitle}>
                      Detected {scanResults.darkPatterns.length} dark patterns at {scanResults.detectedAt}
                    </Text>
                    
                    <View style={styles.detectedPatternsContainer}>
                      <Text style={styles.detectedPatternsTitle}>Detected Dark Patterns:</Text>
                      {scanResults.darkPatterns.map((pattern: any, index: number) => (
                        <View key={index} style={styles.detectedPatternCard}>
                          <Text style={styles.detectedPatternName}>{pattern.name}</Text>
                          <View style={styles.patternDetails}>
                            <Text style={styles.patternConfidence}>{pattern.confidence}% confidence</Text>
                            <Text style={styles.patternSeverity}>{pattern.severity} severity</Text>
                          </View>
                        </View>
                      ))}
                    </View>
                    
                    <View style={styles.recommendationsContainer}>
                      <Text style={styles.recommendationsTitle}>Recommendations:</Text>
                      {scanResults.recommendations.map((rec: string, index: number) => (
                        <View key={index} style={styles.recommendationItem}>
                          <Ionicons name="checkmark-circle" size={16} color="#10b981" />
                          <Text style={styles.recommendationText}>{rec}</Text>
                        </View>
                      ))}
                    </View>
                  </View>
                )}
              </>
            )}
          </View>
        )}

        {/* Search Results */}
        <View style={styles.section}>
          <View style={styles.resultsHeader}>
            <Text style={styles.sectionTitle}>Products Database</Text>
            <Text style={styles.resultsCount}>{filteredProducts.length} products</Text>
          </View>

          {filteredProducts.length === 0 ? (
            <View style={styles.emptyState}>
              <Ionicons name="search" size={64} color="#d1d5db" />
              <Text style={styles.emptyStateTitle}>No products found</Text>
              <Text style={styles.emptyStateText}>
                Try a different search term or category filter
              </Text>
            </View>
          ) : (
            <View style={styles.resultsList}>
              {filteredProducts.map((product) => (
                <TouchableOpacity
                  key={product.id}
                  style={styles.productCard}
                  onPress={() => navigation.navigate('ProductDetail', { productId: product.id })}
                >
                  <View style={styles.productHeader}>
                    <Text style={styles.productIcon}>{product.icon}</Text>
                    <View style={[styles.riskBadge, { backgroundColor: getRiskColor(product.riskScore) }]}>
                      <Text style={styles.riskScore}>{product.riskScore}</Text>
                    </View>
                  </View>
                  <View style={styles.productInfo}>
                    <Text style={styles.productName}>{product.name}</Text>
                    <Text style={styles.productCategory}>{product.category.replace('_', ' ')}</Text>
                    <Text style={styles.productDescription} numberOfLines={2}>
                      {product.description}
                    </Text>
                    <View style={styles.darkPatternsPreview}>
                      {product.darkPatterns.slice(0, 2).map((dp, index) => (
                        <View key={index} style={styles.darkPatternTag}>
                          <Text style={styles.darkPatternText} numberOfLines={1}>
                            {dp.pattern.name}
                          </Text>
                        </View>
                      ))}
                      {product.darkPatterns.length > 2 && (
                        <Text style={styles.morePatterns}>+{product.darkPatterns.length - 2} more</Text>
                      )}
                    </View>
                  </View>
                </TouchableOpacity>
              ))}
            </View>
          )}
        </View>
      </ScrollView>
    </SafeAreaView>
  );
}

