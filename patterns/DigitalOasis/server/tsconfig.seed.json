{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist-seed",
    "rootDir": "../src/data"
  },
  "include": ["../src/data/*.ts"],
  "exclude": ["node_modules"]
}